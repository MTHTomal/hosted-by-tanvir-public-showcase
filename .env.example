# Hosted by Tanvir environment template
# All values below are placeholders or safe local defaults. Never commit secrets.

# Django core
# Required with DEBUG=0; DEBUG=1 enables the local development defaults.
DEBUG=1
SECRET_KEY=placeholder
# Optional alternate base env file path; .env is used when blank.
ENV_FILE=

# Local/production database
# SQLite is the simplest local path. Use a real PostgreSQL/Supabase URL in production.
DATABASE_URL=sqlite:///db.sqlite3

# Hosts and CSRF
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# Render can populate this with the service hostname in production.
RENDER_EXTERNAL_HOSTNAME=
# Used only when DEBUG=0; keep redirects off for the basic local path.
SECURE_SSL_REDIRECT=0

# Cloudinary/media
# Optional for basic local development; required with real values when DEBUG=0.
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Celery/Redis
# Optional task-queue foundation; core correctness does not require Redis.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=1
CELERY_TASK_EAGER_PROPAGATES=1
NOTIFICATIONS_USE_CELERY=0

# Email
# Console email keeps password-reset development local; configure SMTP only when needed.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=webmaster@localhost
SERVER_EMAIL=root@localhost
PASSWORD_RESET_TIMEOUT=259200

# Optional application links
DISCORD_LINK=

# Render/deployment
# Keep blank locally; use the Render service hostname in the deployment environment.
# RENDER_EXTERNAL_HOSTNAME is declared above with hosts/CSRF because settings uses it there.
